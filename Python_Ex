class ReverseWords:
    def reverse(self, text):
        words = text.split()
        return " ".join(words[::-1])


# Example
obj = ReverseWords()

input_string = "hello world"
print("Input String :", input_string)
print("Expected Output :", obj.reverse(input_string))





